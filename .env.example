# ─────────────────────────────────────────────────────────
# 🤖 Autonomous Research Agent - Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── OpenAI Configuration ──────────────────────────────────
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini          # Options: gpt-4o, gpt-4o-mini, gpt-3.5-turbo

# ── Ollama Configuration (Local LLM Alternative) ──────────
# Install Ollama from: https://ollama.ai
# Run: ollama pull llama3.2
USE_OLLAMA=false                   # Set to "true" to use local Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2             # Options: llama3.2, mistral, codellama, etc.

# ── Search Provider Configuration ────────────────────────
SEARCH_PROVIDER=duckduckgo         # Options: duckduckgo, tavily
TAVILY_API_KEY=tvly-your-api-key-here  # Required if SEARCH_PROVIDER=tavily
                                   # Get your key at: https://app.tavily.com

# ── Agent Configuration ───────────────────────────────────
MAX_TOKENS=1500                    # Max tokens for LLM responses
MAX_SOURCES=8                      # Default number of web sources to use

# ── Vector DB Configuration ───────────────────────────────
CHROMA_DB_PATH=./chroma_db         # Where to store the vector database

# ── Output Configuration ──────────────────────────────────
OUTPUT_DIR=./outputs               # Where to save generated files
